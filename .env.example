# Copy to .env for local live Jira validation. Do not commit .env.
JIRA_BASE_URL=http://jira.example.local/
JIRA_LIVE_TEST=1

# Use either JIRA_USER_EMAIL or JIRA_USER.
JIRA_USER_EMAIL=agent@example.com
# JIRA_USER=agent

# Use either JIRA_API_TOKEN or JIRA_PASSWORD.
JIRA_API_TOKEN=replace_me
# JIRA_PASSWORD=replace_me

# Bypass proxies for internal Jira hosts when needed.
NO_PROXY=jira.example.local
no_proxy=jira.example.local

# Only set this after creating a dedicated Jira CLI test project.
# Use T1 as a placeholder only; put the real project key in local .env.
# Live write tests must create only JIRA_CLI_TEST_* artifacts in this project.
# JIRA_LIVE_PROJECT=T1
